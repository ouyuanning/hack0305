# ============================================
# GitHub Issue 智能管理系统 - 环境变量模板
# 复制本文件为 .env 并填入实际值：cp .env.example .env
# ============================================

# GitHub API
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# AI - Claude（可选，使用 Claude 时填写）
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxx

# AI - 通义千问（推荐，阿里云百炼）
# 获取方式：https://help.aliyun.com/zh/model-studio/first-api-call-to-qwen
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# MatrixOne 数据库连接
# 本地 moi-core 开发环境示例：
MATRIXONE_HOST=127.0.0.1
MATRIXONE_PORT=6001
MATRIXONE_USER=dump
MATRIXONE_PASSWORD=111
# 云端 MatrixOne 示例（用户名含冒号，需完整填写）：
# MATRIXONE_HOST=freetier-01.cn-hangzhou.cluster.matrixonecloud.cn
# MATRIXONE_PORT=6001
# MATRIXONE_USER=019c3caf-ae5a-7ced-ac5b-37d070f153f5:admin:accountadmin
# MATRIXONE_PASSWORD=your_password

# SMTP 邮件（163邮箱授权码）
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
