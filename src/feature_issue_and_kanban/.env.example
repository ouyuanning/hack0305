# feature_issue_and_kanban 环境变量模板
# 复制为 .env 并填写

# ========== 核心配置（必须） ==========
QWEN_API_KEY=sk-your-qwen-api-key
# 或 DASHSCOPE_API_KEY
GITHUB_TOKEN=ghp_your-github-token

# ========== 部署环境 ==========
CLOUD_DEPLOYMENT=false

# ========== 云端存储 ==========
S3_BUCKET=issue-assistant-images
AWS_REGION=us-west-2

# ========== 缓存（云端） ==========
REDIS_URL=redis://localhost:6379

# ========== 本地监控（监听浏览器当前页，用于关联 Issue）==========
MONITOR_ENABLED=true
# Chrome 需以调试模式启动：open -a "Google Chrome" --args --remote-debugging-port=9222

# ========== 图片上传（本地） ==========
IMGUR_CLIENT_ID=your-imgur-client-id
